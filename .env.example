# Docker / app image
ONEAPI_IMAGE=justsong/one-api:latest
MYSQL_IMAGE=mysql:8.4

# Runtime
TZ=America/New_York
ONEAPI_HOST_PORT=3015
ONEAPI_BIND_HOST=127.0.0.1
ONEAPI_CONTAINER_NAME=aiusage-one-api
MYSQL_CONTAINER_NAME=aiusage-mysql

# Shared edge network so hosting/Caddy can reverse proxy the container directly.
SHARED_EDGE_NETWORK=shared_edge

# MySQL backing database for one-api.
MYSQL_DATABASE=aiusage_db
MYSQL_USER=aiusage
MYSQL_PASSWORD=change-me-app-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# one-api core DSN.
# Official one-api uses SQL_DSN for MySQL and other SQL backends.
SQL_DSN=aiusage:change-me-app-password@tcp(aiusage-mysql:3306)/aiusage_db

# one-api runtime toggles.
MEMORY_CACHE_ENABLED=true

# Optional process-level outbound proxies.
# Use these only if you want all channel traffic or user-content fetches to traverse a single proxy.
RELAY_PROXY=
USER_CONTENT_REQUEST_PROXY=

# Optional current infra placeholders.
# Local AI runtime currently lives on VPS2.
OLLAMA_BASE_URL=http://10.20.0.2:11434
OLLAMA_PRIMARY_MODEL=ollama/qwen2.5:3b
OLLAMA_SECONDARY_MODEL=ollama/phi4-mini:3.8b
OLLAMA_FALLBACK_MODEL=ollama/llama3.2:3b
ONEAPI_CHANNEL_GROUP=default

# Current remote model placeholders already in the broader stack.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

TOGETHERAI_API_KEY=
TOGETHERAI_BASE_URL=https://api.together.xyz/v1
TOGETHERAI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Major US / global provider placeholders.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_MODEL=gemini-2.5-pro

XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4

MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-large-latest

PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar-pro

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-5

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Major Chinese / China-adjacent provider placeholders.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

ALIBABA_DASHSCOPE_API_KEY=
ALIBABA_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIBABA_DASHSCOPE_MODEL=qwen-max

ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4.5

MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2-0711-preview

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M1

BAIDU_QIANFAN_API_KEY=
BAIDU_QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2
BAIDU_QIANFAN_MODEL=ernie-4.0-turbo

TENCENT_HUNYUAN_API_KEY=
TENCENT_HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
TENCENT_HUNYUAN_MODEL=hunyuan-turbo

VOLCENGINE_ARK_API_KEY=
VOLCENGINE_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_ARK_MODEL=doubao-seed-1-6-250615

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

STEPFUN_API_KEY=
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_MODEL=step-2-16k

YI_API_KEY=
YI_BASE_URL=https://api.lingyiwanwu.com/v1
YI_MODEL=yi-lightning

# Proxy service inventory placeholders currently used elsewhere in the stack.
# one-api does not consume these directly unless you point RELAY_PROXY or USER_CONTENT_REQUEST_PROXY to one of them.
EVOMI_PROXY_URL=
BRIGHTDATA_PROXY_URL=
DECODO_PROXY_URL=
FLOPPYDATA_PROXY_URL=

# Optional AI gateway / proxy placeholders.
CLOUDFLARE_AI_GATEWAY_BASE_URL=
CLOUDFLARE_AI_GATEWAY_TOKEN=
